---
import BaseLayout from '../layouts/BaseLayout.astro';
import Bi from '../components/shared/Bi.astro';
import Callout from '../components/shared/Callout.astro';
import Section from '../components/mechanics/Section.astro';
import DataTable from '../components/mechanics/DataTable.astro';
import { FIELD_PRODUCTION, CP_REQUIRED, MERCHANTS } from '../data/travian';

const fieldRows: (string | number)[][] = [];
for (let L = 0; L <= 20; L += (L < 10 ? 1 : L < 15 ? 2 : 1)) {
  fieldRows.push([`Lv ${L}`, FIELD_PRODUCTION[L] ?? 0]);
}

const cpRows = CP_REQUIRED.map(r => [
  `#${r.village}`,
  r.delta.toLocaleString(),
  r.cumulative.toLocaleString(),
]);

const merchantRows = Object.entries(MERCHANTS).map(([tribe, m]) => [
  tribe.charAt(0).toUpperCase() + tribe.slice(1),
  m.capacity,
  `${m.speed} tiles/hr`,
]);
---
<BaseLayout
  titleZh="遊戲機制 · Travian Guide"
  titleEn="Game Mechanics · Travian Guide"
>
  <section style="padding: var(--space-7) var(--space-5); background: var(--bg-1); border-bottom: 1px solid var(--border-0);">
    <div style="max-width: 860px; margin: 0 auto;">
      <span style="font-family: var(--font-mono); font-size: 12px; color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase;">
        <Bi zh="遊戲機制 · T4.6 · 1x 速度" en="Game Mechanics · T4.6 · 1x speed" />
      </span>
      <h1 style="font-size: var(--fs-4xl); margin: 8px 0 12px; letter-spacing: -0.02em;">
        <Bi zh="遊戲機制完整參考" en="Complete Mechanics Reference" />
      </h1>
      <p style="color: var(--text-1); font-size: var(--fs-md); line-height: var(--lh-relaxed);">
        <Bi
          zh="戰鬥、建築、資源、文化點、英雄、擴張。所有公式與數值均對照 kirilloid T4.6 與 support.travian.com 官方條目。"
          en="Combat, buildings, resources, culture points, hero, expansion. All formulas and constants verified against kirilloid T4.6 source and support.travian.com."
        />
      </p>
    </div>
  </section>

  <div style="max-width: 860px; margin: 0 auto; padding: 0 var(--space-5);">

    <Section id="battle" titleZh="戰鬥系統" titleEn="Battle system" eyebrow="Combat">
      <h3><Bi zh="損失公式" en="Damage formula" /></h3>
      <p>
        <Bi
          zh="Travian 戰鬥使用「力量對比」的乘方公式："
          en="Travian battles use a power-ratio formula:"
        />
      </p>
      <pre>loser_ratio = (loser_power / winner_power) ^ 1.5</pre>
      <p>
        <Bi
          zh="當雙方力量接近，兩邊都死慘；懸殊時輸的幾乎全滅。牆、Residence/Palace、Stone Mason 等加成都乘在防守力上，不是固定值。"
          en="When powers are close, both sides take heavy losses; with a lopsided ratio the loser is nearly wiped. Wall, Residence/Palace, and Stone Mason bonuses multiply into defender power — they are not flat buffs."
        />
      </p>

      <h3><Bi zh="牆壁每級加成" en="Wall bonus per level" /></h3>
      <DataTable
        headers={[{ zh: '部族', en: 'Tribe' }, { zh: '牆壁', en: 'Wall' }, { zh: '每級加成', en: 'Per level' }]}
        rows={[
          [{ zh: '羅馬人 (Romans)', en: 'Romans' }, { zh: '城牆 (City Wall)', en: 'City Wall' }, '+3.0 %'],
          [{ zh: '高盧人 (Gauls)', en: 'Gauls' }, { zh: '木牆 (Palisade)', en: 'Palisade' }, '+2.5 %'],
          [{ zh: '日耳曼人 (Teutons)', en: 'Teutons' }, { zh: '土牆 (Earth Wall)', en: 'Earth Wall' }, '+2.0 %'],
          [{ zh: '埃及人 (Egyptians)', en: 'Egyptians' }, { zh: '石牆 (Stone Wall)', en: 'Stone Wall' }, '+2.5 %'],
          [{ zh: '匈奴 (Huns)', en: 'Huns' }, { zh: '臨時的墻 (Makeshift Wall)', en: 'Makeshift Wall' }, '+1.5 %'],
          [{ zh: '維京人 (Vikings)', en: 'Vikings' }, { zh: '障礙物 (Barricade)', en: 'Barricade' }, '+1.5 %'],
          [{ zh: '斯巴達人 (Spartans)', en: 'Spartans' }, { zh: '防禦牆 (Defensive Wall)', en: 'Defensive Wall' }, '+2.5 %'],
        ]}
      />

      <h3><Bi zh="Residence / Palace 防禦" en="Residence / Palace defense" /></h3>
      <p>
        <Bi
          zh="Lv L 的行宮 / 皇宮提供 2 × L² 的基礎防禦。滿等 Lv20 = 800 防（受牆 % 加成放大）。這是為什麼「守 cap 時升 res 到 20」很有價值。"
          en="Residence / Palace at level L grants a flat 2 × L² base defense. Lv 20 = 800 def (scaled up by wall %). This is why pushing Residence to Lv 20 in a capital is worthwhile."
        />
      </p>
    </Section>

    <Section id="building" titleZh="建築系統" titleEn="Building system" eyebrow="Buildings">
      <h3><Bi zh="田地分布" en="Field layouts" /></h3>
      <p>
        <Bi
          zh="每個村莊有 18 格資源田。常見分布：4-4-4-6（標準）、3-4-4-7（7c）、3-3-3-9（9c）、1-1-1-15（15c）。首都通常選 15c / 9c 來衝產量。"
          en="Every village has 18 resource-field tiles. Common layouts: 4-4-4-6 (standard), 3-4-4-7 (7c), 3-3-3-9 (9c), 1-1-1-15 (15c). Capitals usually pick 15c or 9c to push production."
        />
      </p>

      <h3><Bi zh="村莊大樓加速公式" en="Main Building speed-up" /></h3>
      <pre>build_time(L) = base_time × 0.964 ^ (MB_level − 1)</pre>
      <p>
        <Bi
          zh="村莊大樓每升一級，後續建築時間減少約 3.6%（複利）。Lv 10 ≈ 72% 時間；Lv 20 ≈ 50%（約加倍速度）。"
          en="Each Main Building level shaves ~3.6% off build time (compounded). Lv 10 ≈ 72% of base, Lv 20 ≈ 50% (roughly 2× speed)."
        />
      </p>

      <h3><Bi zh="加成建築（每級 +5%，滿 Lv5 = +25%）" en="Bonus buildings (+5%/lv, max +25% at Lv5)" /></h3>
      <ul>
        <li>鋸木廠 (Sawmill) → Wood · <Bi zh="需 伐木場 (Woodcutter) Lv10 + 村莊大樓 Lv5" en="needs Woodcutter Lv10 + MB Lv5" /></li>
        <li>磚廠 (Brickyard) → Clay · <Bi zh="需 泥坑 (Clay Pit) Lv10 + 村莊大樓 Lv5" en="needs Clay Pit Lv10 + MB Lv5" /></li>
        <li>鋼鐵鑄造廠 (Iron Foundry) → Iron · <Bi zh="需 鐵礦場 (Iron Mine) Lv10 + 村莊大樓 Lv5" en="needs Iron Mine Lv10 + MB Lv5" /></li>
        <li>麵粉廠 (Grain Mill) → Crop · <Bi zh="需 農場 (Cropland) Lv5 + 村莊大樓 Lv5" en="needs Cropland Lv5 + MB Lv5" /></li>
        <li>麵包店 (Bakery) → Crop · <Bi zh="需 農場 (Cropland) Lv10 + 麵粉廠 (Grain Mill) Lv5" en="needs Cropland Lv10 + Grain Mill Lv5" /></li>
      </ul>
      <p>
        <Bi
          zh="糧食有兩棟加成建築（麵粉廠 + 麵包店），總共可疊加 +50%。其他資源只有一棟 = +25% 上限。"
          en="Crop has two bonus buildings (Grain Mill + Bakery) stacking to +50%. Other resources have one each — capped at +25%."
        />
      </p>
    </Section>

    <Section id="smithy" titleZh="兵種升級 (Smithy)" titleEn="Troop upgrades (Smithy)" eyebrow="Combat">
      <p>
        <Bi
          zh="盔甲廠（Smithy）可以升級每隻兵種的攻擊力 + 防禦力。每次升級需要該兵種的研發完成（兵營 / 馬廄）+ 盔甲廠達對應等級。每隻兵可以升 20 次，總加成約 +24–29%（取決於糧消耗；高糧消耗兵種加成較大）。"
          en="The Smithy upgrades each troop type's attack and defense. Each upgrade requires the unit researched (Barracks / Stable) + Smithy at matching level. Each unit can be upgraded up to 20 times for a total bonus of ~+24–29% (varies by upkeep; higher-upkeep units gain more)."
        />
      </p>
      <h3><Bi zh="計算公式" en="Formula" /></h3>
      <pre>improved = base × 1.015^level   <Bi zh="（簡化式）" en="(simplified)" /></pre>
      <pre>improved = base + (base + 300 × upkeep ÷ 7) × (1.007^level − 1)   <Bi zh="（精確式）" en="(exact)" /></pre>
      <p>
        <Bi
          zh="精確公式表示「高糧消耗的兵種升級每級得到的絕對加成更大」 — 例如 EC（upkeep 4）每級加成幅度大於 EI（upkeep 3）。簡化式 ~1.5% 適合快速估算。"
          en="The exact formula means high-upkeep units gain a larger absolute bonus per level — e.g., EC (upkeep 4) benefits more per level than EI (upkeep 3). The simplified ~1.5%/level approximation is fine for quick estimates."
        />
      </p>
      <DataTable
        caption={{ zh: '常用兵種 Lv 20 升級加成範例', en: 'Lv 20 upgrade bonus on common units' }}
        headers={[
          { zh: '單位', en: 'Unit' },
          { zh: '基礎', en: 'Base' },
          { zh: 'Lv 20 攻擊', en: 'Lv 20 attack' },
          { zh: '提升', en: 'Gain' },
        ]}
        rows={[
          [{ zh: '帝國兵 (Imperian, 羅馬人)', en: 'Imperian (Roman)' }, '70', '~87', '+24%'],
          [{ zh: '將軍騎士 (EC, 羅馬人)', en: 'EC (Roman)' }, '180', '~233', '+29%'],
          [{ zh: '海頓聖騎 (Haeduan, 高盧人)', en: 'Haeduan (Gaul)' }, '140', '~180', '+29%'],
          [{ zh: '條頓騎士 (TK, 日耳曼人)', en: 'Teutonic Knight' }, '150', '~192', '+28%'],
          [{ zh: '掠奪者 (Marauder, 匈奴)', en: 'Marauder (Hun)' }, '180', '~226', '+26%'],
          [{ zh: '科林斯破壞者 (Corinthian Crusher, 斯巴達人)', en: 'Corinthian (Spartan)' }, '195', '~250', '+28%'],
        ]}
      />
      <Callout kind="tip" titleZh="升幾級 vs 多訓兵？" titleEn="Upgrade vs more troops?">
        <p>
          <Bi
            zh="官方部落格 'More Troops or Smithy Upgrades?' 結論：低等級（0→Lv 5）升級超划算，因為單級成本低。Lv 15→20 成本暴增（每級 ×1.28），通常多訓 50 隻兵收益更高。實戰：每隻主力兵升到 Lv 5，再決定要不要繼續。"
            en="Per the official 'More Troops or Smithy Upgrades?' blog: low levels (0 → Lv 5) are extremely cheap — always do them. Lv 15 → 20 costs explode (×1.28 per level); usually 50 more troops > 5 more upgrade levels. Practical rule: get every key unit to Smithy Lv 5 first, then evaluate."
          />
        </p>
      </Callout>
      <p style="font-size: var(--fs-sm); color: var(--text-2);">
        <Bi
          zh="T4 Travian Legends 把舊版的 Blacksmith（攻擊）+ Armoury（防禦）合併成一個 Smithy；同一棟同時升攻防。"
          en="T4 Travian Legends merged the old Blacksmith (attack) + Armoury (defense) into a single Smithy that upgrades both at once."
        />
      </p>

      <h3><Bi zh="Academy 研發成本" en="Academy research cost" /></h3>
      <p>
        <Bi
          zh="官方未公布正式公式。社群共識（kirilloid 驗證）：研發單位的資源成本 ≈ 該單位訓練成本（木+土+鐵+糧）相關係數，並隨 Academy 等級調整。Academy 等級需求依兵種 tier："
          en="No official formula is published. Community consensus (kirilloid-verified): a unit's research cost scales from the unit's training cost × tier-specific factor, with Academy-level adjustments. Academy level required per unit tier:"
        />
      </p>
      <DataTable
        caption={{ zh: '各兵種 tier 所需 Academy 等級（社群資料）', en: 'Academy level required per unit tier (community)' }}
        headers={[
          { zh: 'Tier', en: 'Tier' },
          { zh: '例子', en: 'Example' },
          { zh: '需 Academy Lv', en: 'Academy Lv needed' },
        ]}
        rows={[
          ['T1', { zh: 'Clubswinger / Phalanx（羅馬 Legionnaire 預設解鎖）', en: 'Clubswinger / Phalanx (Roman Legionnaire default-unlocked)' }, '1'],
          ['T2-T3', { zh: '矛兵 / 劍士 / 斧頭兵', en: 'Spearman / Swordsman / Axeman' }, '3'],
          ['T4 Scout', { zh: '偵察兵 / 探子', en: 'Scout / Spotter' }, '3'],
          ['T5-T6 Cavalry', { zh: '條頓騎士 / 帝國騎士', en: 'Teutonic Knight / Equites Imperatoris' }, '5-10'],
          ['T7 Ram', { zh: '破城槌', en: 'Battering Ram' }, '10'],
          ['T8 Catapult', { zh: '火焰投石機 / 弩炮', en: 'Fire Catapult / Catapult' }, '15'],
          ['T9 Chief', { zh: '參議員 / 司令官 / 族長', en: 'Senator / Chief / Chieftain' }, '20'],
          ['T10 Settler', { zh: '開拓者', en: 'Settler' }, { zh: '不需研發（行宮 / 皇宮 Lv10/15/20 訓練）', en: 'No research (trained at Residence/Palace Lv10/15/20)' }],
        ]}
      />
      <p style="font-size: var(--fs-sm); color: var(--text-2);">
        <Bi
          zh="※ 單位實際研發成本數值可在遊戲內 Academy 介面查看；官方未發布靜態表。"
          en="※ Exact research costs appear in the in-game Academy UI; Travian has not published a static cost table."
        />
      </p>
    </Section>

    <Section id="resources" titleZh="資源產量 & 綠洲" titleEn="Resource production & oases" eyebrow="Resources">
      <h3><Bi zh="田地產量（每小時，1x 速度）" en="Field production (per hour, 1x speed)" /></h3>
      <DataTable
        caption={{ zh: '所有四種資源共用同一張表', en: 'Same values apply to all 4 field types' }}
        headers={[{ zh: '等級', en: 'Level' }, { zh: '產量 /小時', en: 'Production /hr' }]}
        rows={fieldRows}
      />

      <h3><Bi zh="產量公式" en="Production formula" /></h3>
      <pre>final = base × (1 + bonus_building% + oasis% + gold%)</pre>
      <p>
        <Bi
          zh="所有加成以加法疊加（不是乘法）。例：L18 crop 2240/hr × (1 + 0.50 bakery + 1.50 crop oases + 0.25 gold) = 2240 × 3.25 = 7280/hr 每格。"
          en="All bonuses stack additively (not multiplicatively). Example: L18 crop 2240/hr × (1 + 0.50 bakery + 1.50 crop oases + 0.25 gold) = 2240 × 3.25 = 7,280/hr per field."
        />
      </p>

      <h3><Bi zh="綠洲類型" en="Oasis types" /></h3>
      <ul>
        <li><Bi zh="單一資源 +25%（最常見）" en="Single +25% (most common)" /></li>
        <li><Bi zh="雙資源 +25% + 糧 +25%" en="Dual +25% with crop +25%" /></li>
        <li><Bi zh="單一資源 +50%（較稀少；糧 +50% 是首都必搶）" en="Single +50% (rarer; crop +50% is the capital prize)" /></li>
      </ul>
      <p>
        <Bi
          zh="佔領綠洲需要英雄宅：Lv10 可佔 1 塊、Lv15 可佔 2 塊、Lv20 可佔 3 塊。綠洲必須在村莊 7×7 範圍內。"
          en="Capturing oases needs Hero's Mansion Lv10 (1 slot), Lv15 (2), Lv20 (3). Oasis must be within the village's 7×7 area."
        />
      </p>
      <Callout kind="tip" titleZh="實戰建議" titleEn="Practical advice">
        <p>
          <Bi
            zh={`先用「綠洲 ROI 計算器」算出回本天數。15c 首都 + 50% crop 綠洲 + HM Lv10 = 1.8 天回本；若是單一 25% 綠洲就要 3–5 天，得評估值不值。詳見下方 #roi-tables 的 Lumi 官方 ROI 表。`}
            en={`Use the Oasis ROI calculator first. A 15c cap + 50% crop oasis + HM Lv10 ≈ 1.8 days payback. A single 25% oasis takes 3–5 days — weigh against other upgrades. See Lumi's official ROI tables below in #roi-tables.`}
          />
        </p>
      </Callout>
    </Section>

    <Section id="roi-tables" titleZh="Lumi ROI 參考表（Table 2 / 3）" titleEn="Lumi ROI reference tables (Table 2 / 3)" eyebrow="ROI">
      <p>
        <Bi
          zh="以下兩張表直接搬自 Lumi Travian Guide §5.3。用來快速判斷：(1) 單格資源田升級多久回本、(2) 佔綠洲值不值。所有數值已包含加成建築 + 25% 金幣產量加成，對照 Lumi 推薦的建築順序計算。"
          en="Both tables below are reproduced from the Lumi Travian Guide §5.3. Use them to quickly judge: (1) how many days a single field-level upgrade takes to break even, and (2) whether capturing a given oasis is worth it. All values already include bonus-building bonuses and 25% gold production bonus, assuming Lumi's recommended build order."
        />
      </p>

      <h3><Bi zh="Table 2 — 資源田每級 ROI（天）" en="Table 2 — Field ROI by level (days)" /></h3>
      <DataTable
        caption={{
          zh: 'Lv 1 → 10；包含加成建築 +25% 產量加成（按 Lumi 順序）+ 25% 金幣加成。主要用來比較「首都糧田 vs spawn village 資源田」何時優先升。',
          en: 'Lv 1 → 10; includes +25% bonus-building production (per Lumi build order) + 25% gold production bonus. Mainly useful when comparing spawn-village field upgrades against cap-village fields.',
        }}
        headers={[
          { zh: '等級', en: 'Level' },
          { zh: '糧 Crop', en: 'Crop' },
          { zh: '土 Clay', en: 'Clay' },
          { zh: '木 Wood', en: 'Wood' },
          { zh: '鐵 Iron', en: 'Iron' },
        ]}
        rows={[
          ['Lv 1', '1.19', '1.19', '1.19', '1.29'],
          ['Lv 2', '2.31', '2.33', '2.31', '2.50'],
          ['Lv 3', '2.90', '2.92', '2.90', '3.15'],
          ['Lv 4', '3.88', '3.90', '3.88', '4.20'],
          ['Lv 5', '4.32', '4.31', '4.32', '4.67'],
          ['Lv 6', '4.51', '4.51', '4.51', '4.88'],
          ['Lv 7', '6.21', '6.46', '6.46', '6.97'],
          ['Lv 8', '6.65', '7.19', '7.19', '7.77'],
          ['Lv 9', '7.15', '7.15', '7.15', '7.72'],
          ['Lv 10', '8.54', '9.42', '9.42', '10.18'],
        ]}
      />
      <p style="font-size: var(--fs-sm); color: var(--text-2);">
        <Bi
          zh="觀察重點：Lv 1–6 幾乎都在 5 天內回本（極便宜），到 Lv 7 起 ROI 跳一截（需要加成建築才補得回）。Iron 因為單價略高於木/土，全程 ROI 最久。"
          en="Takeaway: Lv 1–6 all pay back within ~5 days (dirt cheap), but from Lv 7 onward ROI jumps a tier (bonus buildings are needed to catch up). Iron has the longest ROI end-to-end because of its slightly higher cost."
        />
      </p>

      <h3><Bi zh="Table 3 — 綠洲 ROI（所有田 Lv 10）" en="Table 3 — Oasis ROI (all fields at Lv 10)" /></h3>
      <p style="font-size: var(--fs-sm); color: var(--text-2);">
        <Bi
          zh="格式：HMx → y 代表「英雄宅 Lv x、y 天回本」。括弧內是 Lumi 推薦「在田升到第幾 → 第幾級時捕綠洲最划算」（25/25 雙綠洲不含建議）。"
          en={`Format: "HMx → y" means "Hero's Mansion Lv x, y days to break even". Numbers in brackets = Lumi's recommended trigger point ("capture the oasis when your fields are at Lv X → Y"). 25/25 dual oases have no bracketed recommendation.`}
        />
      </p>
      <div class="table-wrap oasis-roi-wrap">
        <table class="oasis-roi">
          <thead>
            <tr>
              <th><span class="bi"><span data-lang="zh">首都配置</span><span data-lang="en">Crop layout</span></span></th>
              <th><span class="bi"><span data-lang="zh">50% 糧綠洲</span><span data-lang="en">50% crop oasis</span></span></th>
              <th><span class="bi"><span data-lang="zh">25% / 25% 雙綠洲</span><span data-lang="en">25% / 25% dual oasis</span></span></th>
              <th><span class="bi"><span data-lang="zh">25% 糧綠洲</span><span data-lang="en">25% crop oasis</span></span></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="layout">15c</td>
              <td><div class="hm">HM10 → 1.83 <span class="hint">(11→7)</span></div><div class="hm">HM15 → 6.08</div><div class="hm">HM20 → 25.32</div></td>
              <td><div class="hm">HM10 → 3.40</div><div class="hm">HM15 → 11.41</div><div class="hm">HM20 → 47.47</div></td>
              <td><div class="hm">HM10 → 3.63 <span class="hint">(8→9)</span></div><div class="hm">HM15 → 12.16</div><div class="hm">HM20 → 50.62</div></td>
            </tr>
            <tr>
              <td class="layout">9c</td>
              <td><div class="hm">HM10 → 3.01 <span class="hint">(all 8)</span></div><div class="hm">HM15 → 10.14</div><div class="hm">HM20 → 42.20</div></td>
              <td><div class="hm">HM10 → 4.53</div><div class="hm">HM15 → 15.21</div><div class="hm">HM20 → 63.30</div></td>
