---
import BaseLayout from '../layouts/BaseLayout.astro';
import Bi from '../components/shared/Bi.astro';
import Callout from '../components/shared/Callout.astro';
import Section from '../components/mechanics/Section.astro';
import DataTable from '../components/mechanics/DataTable.astro';
import { FIELD_PRODUCTION, CP_REQUIRED, MERCHANTS } from '../data/travian';

const fieldRows: (string | number)[][] = [];
for (let L = 0; L <= 20; L += (L < 10 ? 1 : L < 15 ? 2 : 1)) {
  fieldRows.push([`Lv ${L}`, FIELD_PRODUCTION[L] ?? 0]);
}

const cpRows = CP_REQUIRED.map(r => [
  `#${r.village}`,
  r.delta.toLocaleString(),
  r.cumulative.toLocaleString(),
]);

const merchantRows = Object.entries(MERCHANTS).map(([tribe, m]) => [
  tribe.charAt(0).toUpperCase() + tribe.slice(1),
  m.capacity,
  `${m.speed} tiles/hr`,
]);
---
<BaseLayout
  titleZh="遊戲機制 · Travian Guide"
  titleEn="Game Mechanics · Travian Guide"
>
  <section style="padding: var(--space-7) var(--space-5); background: var(--bg-1); border-bottom: 1px solid var(--border-0);">
    <div style="max-width: 860px; margin: 0 auto;">
      <span style="font-family: var(--font-mono); font-size: 12px; color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase;">
        <Bi zh="遊戲機制 · T4.6 · 1x 速度" en="Game Mechanics · T4.6 · 1x speed" />
      </span>
      <h1 style="font-size: var(--fs-4xl); margin: 8px 0 12px; letter-spacing: -0.02em;">
        <Bi zh="遊戲機制完整參考" en="Complete Mechanics Reference" />
      </h1>
      <p style="color: var(--text-1); font-size: var(--fs-md); line-height: var(--lh-relaxed);">
        <Bi
          zh="戰鬥、建築、資源、文化點、英雄、擴張。所有公式與數值均對照 kirilloid T4.6 與 support.travian.com 官方條目。"
          en="Combat, buildings, resources, culture points, hero, expansion. All formulas and constants verified against kirilloid T4.6 source and support.travian.com."
        />
      </p>
    </div>
  </section>

  <div style="max-width: 860px; margin: 0 auto; padding: 0 var(--space-5);">

    <Section id="battle" titleZh="戰鬥系統" titleEn="Battle system" eyebrow="Combat">
      <h3><Bi zh="損失公式" en="Damage formula" /></h3>
      <p>
        <Bi
          zh="Travian 戰鬥使用「力量對比」的乘方公式："
          en="Travian battles use a power-ratio formula:"
        />
      </p>
      <pre>loser_ratio = (loser_power / winner_power) ^ 1.5</pre>
      <p>
        <Bi
          zh="當雙方力量接近，兩邊都死慘；懸殊時輸的幾乎全滅。牆、Residence/Palace、Stone Mason 等加成都乘在防守力上，不是固定值。"
          en="When powers are close, both sides take heavy losses; with a lopsided ratio the loser is nearly wiped. Wall, Residence/Palace, and Stone Mason bonuses multiply into defender power — they are not flat buffs."
        />
      </p>

      <h3><Bi zh="牆壁每級加成" en="Wall bonus per level" /></h3>
      <DataTable
        headers={[{ zh: '部族', en: 'Tribe' }, { zh: '牆壁', en: 'Wall' }, { zh: '每級加成', en: 'Per level' }]}
        rows={[
          [{ zh: '羅馬人 (Romans)', en: 'Romans' }, { zh: '城牆 (City Wall)', en: 'City Wall' }, '+3.0 %'],
          [{ zh: '高盧人 (Gauls)', en: 'Gauls' }, { zh: '柵欄 (Palisade)', en: 'Palisade' }, '+2.5 %'],
          [{ zh: '日耳曼人 (Teutons)', en: 'Teutons' }, { zh: '土牆 (Earth Wall)', en: 'Earth Wall' }, '+2.0 %'],
          [{ zh: '埃及人 (Egyptians)', en: 'Egyptians' }, { zh: '石牆 (Stone Wall)', en: 'Stone Wall' }, '+2.5 %'],
          [{ zh: '匈奴 (Huns)', en: 'Huns' }, { zh: '簡易牆 (Makeshift Wall)', en: 'Makeshift Wall' }, '+1.5 %'],
          [{ zh: '維京人 (Vikings)', en: 'Vikings' }, { zh: '柵欄 (Barricade)', en: 'Barricade' }, '+1.5 %'],
          [{ zh: '斯巴達人 (Spartans)', en: 'Spartans' }, { zh: '柵欄 (Palisade)', en: 'Palisade' }, '+2.5 %'],
        ]}
      />

      <h3><Bi zh="Residence / Palace 防禦" en="Residence / Palace defense" /></h3>
      <p>
        <Bi
          zh="Lv L 的行宮 / 皇宮提供 2 × L² 的基礎防禦。滿等 Lv20 = 800 防（受牆 % 加成放大）。這是為什麼「守 cap 時升 res 到 20」很有價值。"
          en="Residence / Palace at level L grants a flat 2 × L² base defense. Lv 20 = 800 def (scaled up by wall %). This is why pushing Residence to Lv 20 in a capital is worthwhile."
        />
      </p>
    </Section>

    <Section id="building" titleZh="建築系統" titleEn="Building system" eyebrow="Buildings">
      <h3><Bi zh="田地分布" en="Field layouts" /></h3>
      <p>
        <Bi
          zh="每個村莊有 18 格資源田。常見分布：4-4-4-6（標準）、3-4-4-7（7c）、3-3-3-9（9c）、1-1-1-15（15c）。首都通常選 15c / 9c 來衝產量。"
          en="Every village has 18 resource-field tiles. Common layouts: 4-4-4-6 (standard), 3-4-4-7 (7c), 3-3-3-9 (9c), 1-1-1-15 (15c). Capitals usually pick 15c or 9c to push production."
        />
      </p>

      <h3><Bi zh="村莊大樓加速公式" en="Main Building speed-up" /></h3>
      <pre>build_time(L) = base_time × 0.964 ^ (MB_level − 1)</pre>
      <p>
        <Bi
          zh="村莊大樓每升一級，後續建築時間減少約 3.6%（複利）。Lv 10 ≈ 72% 時間；Lv 20 ≈ 50%（約加倍速度）。"
          en="Each Main Building level shaves ~3.6% off build time (compounded). Lv 10 ≈ 72% of base, Lv 20 ≈ 50% (roughly 2× speed)."
        />
      </p>

      <h3><Bi zh="加成建築（每級 +5%，滿 Lv5 = +25%）" en="Bonus buildings (+5%/lv, max +25% at Lv5)" /></h3>
      <ul>
        <li>Sawmill → Wood · <Bi zh="需 Woodcutter Lv10 + 村莊大樓 Lv5" en="needs Woodcutter Lv10 + MB Lv5" /></li>
        <li>Brickyard → Clay · <Bi zh="需 Clay Pit Lv10 + 村莊大樓 Lv5" en="needs Clay Pit Lv10 + MB Lv5" /></li>
        <li>Iron Foundry → Iron · <Bi zh="需 Iron Mine Lv10 + 村莊大樓 Lv5" en="needs Iron Mine Lv10 + MB Lv5" /></li>
        <li>Grain Mill → Crop · <Bi zh="需 Cropland Lv5 + 村莊大樓 Lv5" en="needs Cropland Lv5 + MB Lv5" /></li>
        <li>Bakery → Crop · <Bi zh="需 Cropland Lv10 + Grain Mill Lv5" en="needs Cropland Lv10 + Grain Mill Lv5" /></li>
      </ul>
      <p>
        <Bi
          zh="糧食有兩棟加成建築（Grain Mill + Bakery），總共可疊加 +50%。其他資源只有一棟 = +25% 上限。"
          en="Crop has two bonus buildings (Grain Mill + Bakery) stacking to +50%. Other resources have one each — capped at +25%."
        />
      </p>
    </Section>

    <Section id="smithy" titleZh="兵種升級 (Smithy)" titleEn="Troop upgrades (Smithy)" eyebrow="Combat">
      <p>
        <Bi
          zh="盔甲廠（Smithy）可以升級每隻兵種的攻擊力 + 防禦力。每次升級需要該兵種的研發完成（兵營 / 馬廄）+ 盔甲廠達對應等級。每隻兵可以升 20 次，總加成約 +24–29%（取決於糧消耗；高糧消耗兵種加成較大）。"
          en="The Smithy upgrades each troop type's attack and defense. Each upgrade requires the unit researched (Barracks / Stable) + Smithy at matching level. Each unit can be upgraded up to 20 times for a total bonus of ~+24–29% (varies by upkeep; higher-upkeep units gain more)."
        />
      </p>
      <h3><Bi zh="計算公式" en="Formula" /></h3>
      <pre>improved = base × 1.015^level   <Bi zh="（簡化式）" en="(simplified)" /></pre>
      <pre>improved = base + (base + 300 × upkeep ÷ 7) × (1.007^level − 1)   <Bi zh="（精確式）" en="(exact)" /></pre>
      <p>
        <Bi
          zh="精確公式表示「高糧消耗的兵種升級每級得到的絕對加成更大」 — 例如 EC（upkeep 4）每級加成幅度大於 EI（upkeep 3）。簡化式 ~1.5% 適合快速估算。"
          en="The exact formula means high-upkeep units gain a larger absolute bonus per level — e.g., EC (upkeep 4) benefits more per level than EI (upkeep 3). The simplified ~1.5%/level approximation is fine for quick estimates."
        />
      </p>
      <DataTable
        caption={{ zh: '常用兵種 Lv 20 升級加成範例', en: 'Lv 20 upgrade bonus on common units' }}
        headers={[
          { zh: '單位', en: 'Unit' },
          { zh: '基礎', en: 'Base' },
          { zh: 'Lv 20 攻擊', en: 'Lv 20 attack' },
          { zh: '提升', en: 'Gain' },
        ]}
        rows={[
          [{ zh: '帝國兵 (Imperian, 羅馬人)', en: 'Imperian (Roman)' }, '70', '~87', '+24%'],
          [{ zh: '將軍騎士 (EC, 羅馬人)', en: 'EC (Roman)' }, '180', '~233', '+29%'],
          [{ zh: '海頓聖騎 (Haeduan, 高盧人)', en: 'Haeduan (Gaul)' }, '140', '~180', '+29%'],
          [{ zh: '條頓騎士 (TK, 日耳曼人)', en: 'Teutonic Knight' }, '150', '~192', '+28%'],
          [{ zh: '掠奪者 (Marauder, 匈奴)', en: 'Marauder (Hun)' }, '180', '~226', '+26%'],
          [{ zh: 'Corinthian Crusher (斯巴達人)', en: 'Corinthian (Spartan)' }, '195', '~250', '+28%'],
        ]}
      />
      <Callout kind="tip" titleZh="升幾級 vs 多訓兵？" titleEn="Upgrade vs more troops?">
        <p>
          <Bi
            zh="官方部落格 'More Troops or Smithy Upgrades?' 結論：低等級（0→Lv 5）升級超划算，因為單級成本低。Lv 15→20 成本暴增（每級 ×1.28），通常多訓 50 隻兵收益更高。實戰：每隻主力兵升到 Lv 5，再決定要不要繼續。"
            en="Per the official 'More Troops or Smithy Upgrades?' blog: low levels (0 → Lv 5) are extremely cheap — always do them. Lv 15 → 20 costs explode (×1.28 per level); usually 50 more troops > 5 more upgrade levels. Practical rule: get every key unit to Smithy Lv 5 first, then evaluate."
          />
        </p>
      </Callout>
      <p style="font-size: var(--fs-sm); color: var(--text-2);">
        <Bi
          zh="T4 Travian Legends 把舊版的 Blacksmith（攻擊）+ Armoury（防禦）合併成一個 Smithy；同一棟同時升攻防。"
          en="T4 Travian Legends merged the old Blacksmith (attack) + Armoury (defense) into a single Smithy that upgrades both at once."
        />
      </p>
    </Section>

    <Section id="resources" titleZh="資源產量 & 綠洲" titleEn="Resource production & oases" eyebrow="Resources">
      <h3><Bi zh="田地產量（每小時，1x 速度）" en="Field production (per hour, 1x speed)" /></h3>
      <DataTable
        caption={{ zh: '所有四種資源共用同一張表', en: 'Same values apply to all 4 field types' }}
        headers={[{ zh: '等級', en: 'Level' }, { zh: '產量 /小時', en: 'Production /hr' }]}
        rows={fieldRows}
      />

      <h3><Bi zh="產量公式" en="Production formula" /></h3>
      <pre>final = base × (1 + bonus_building% + oasis% + gold%)</pre>
      <p>
        <Bi
          zh="所有加成以加法疊加（不是乘法）。例：L18 crop 2240/hr × (1 + 0.50 bakery + 1.50 crop oases + 0.25 gold) = 2240 × 3.25 = 7280/hr 每格。"
          en="All bonuses stack additively (not multiplicatively). Example: L18 crop 2240/hr × (1 + 0.50 bakery + 1.50 crop oases + 0.25 gold) = 2240 × 3.25 = 7,280/hr per field."
        />
      </p>

      <h3><Bi zh="綠洲類型" en="Oasis types" /></h3>
      <ul>
        <li><Bi zh="單一資源 +25%（最常見）" en="Single +25% (most common)" /></li>
        <li><Bi zh="雙資源 +25% + 糧 +25%" en="Dual +25% with crop +25%" /></li>
        <li><Bi zh="單一資源 +50%（較稀少；糧 +50% 是首都必搶）" en="Single +50% (rarer; crop +50% is the capital prize)" /></li>
      </ul>
      <p>
        <Bi
          zh="佔領綠洲需要英雄宅：Lv10 可佔 1 塊、Lv15 可佔 2 塊、Lv20 可佔 3 塊。綠洲必須在村莊 7×7 範圍內。"
          en="Capturing oases needs Hero's Mansion Lv10 (1 slot), Lv15 (2), Lv20 (3). Oasis must be within the village's 7×7 area."
        />
      </p>
      <Callout kind="tip" titleZh="實戰建議" titleEn="Practical advice">
        <p>
          <Bi
            zh={`先用「綠洲 ROI 計算器」算出回本天數。15c 首都 + 50% crop 綠洲 + HM Lv10 = 1.8 天回本；若是單一 25% 綠洲就要 3–5 天，得評估值不值。詳見下方 #roi-tables 的 Lumi 官方 ROI 表。`}
            en={`Use the Oasis ROI calculator first. A 15c cap + 50% crop oasis + HM Lv10 ≈ 1.8 days payback. A single 25% oasis takes 3–5 days — weigh against other upgrades. See Lumi's official ROI tables below in #roi-tables.`}
          />
        </p>
      </Callout>
    </Section>

    <Section id="roi-tables" titleZh="Lumi ROI 參考表（Table 2 / 3）" titleEn="Lumi ROI reference tables (Table 2 / 3)" eyebrow="ROI">
      <p>
        <Bi
          zh="以下兩張表直接搬自 Lumi Travian Guide §5.3。用來快速判斷：(1) 單格資源田升級多久回本、(2) 佔綠洲值不值。所有數值已包含加成建築 + 25% 金幣產量加成，對照 Lumi 推薦的建築順序計算。"
          en="Both tables below are reproduced from the Lumi Travian Guide §5.3. Use them to quickly judge: (1) how many days a single field-level upgrade takes to break even, and (2) whether capturing a given oasis is worth it. All values already include bonus-building bonuses and 25% gold production bonus, assuming Lumi's recommended build order."
        />
      </p>

      <h3><Bi zh="Table 2 — 資源田每級 ROI（天）" en="Table 2 — Field ROI by level (days)" /></h3>
      <DataTable
        caption={{
          zh: 'Lv 1 → 10；包含加成建築 +25% 產量加成（按 Lumi 順序）+ 25% 金幣加成。主要用來比較「首都糧田 vs spawn village 資源田」何時優先升。',
          en: 'Lv 1 → 10; includes +25% bonus-building production (per Lumi build order) + 25% gold production bonus. Mainly useful when comparing spawn-village field upgrades against cap-village fields.',
        }}
        headers={[
          { zh: '等級', en: 'Level' },
          { zh: '糧 Crop', en: 'Crop' },
          { zh: '土 Clay', en: 'Clay' },
          { zh: '木 Wood', en: 'Wood' },
          { zh: '鐵 Iron', en: 'Iron' },
        ]}
        rows={[
          ['Lv 1', '1.19', '1.19', '1.19', '1.29'],
          ['Lv 2', '2.31', '2.33', '2.31', '2.50'],
          ['Lv 3', '2.90', '2.92', '2.90', '3.15'],
          ['Lv 4', '3.88', '3.90', '3.88', '4.20'],
          ['Lv 5', '4.32', '4.31', '4.32', '4.67'],
          ['Lv 6', '4.51', '4.51', '4.51', '4.88'],
          ['Lv 7', '6.21', '6.46', '6.46', '6.97'],
          ['Lv 8', '6.65', '7.19', '7.19', '7.77'],
          ['Lv 9', '7.15', '7.15', '7.15', '7.72'],
          ['Lv 10', '8.54', '9.42', '9.42', '10.18'],
        ]}
      />
      <p style="font-size: var(--fs-sm); color: var(--text-2);">
        <Bi
          zh="觀察重點：Lv 1–6 幾乎都在 5 天內回本（極便宜），到 Lv 7 起 ROI 跳一截（需要加成建築才補得回）。Iron 因為單價略高於木/土，全程 ROI 最久。"
          en="Takeaway: Lv 1–6 all pay back within ~5 days (dirt cheap), but from Lv 7 onward ROI jumps a tier (bonus buildings are needed to catch up). Iron has the longest ROI end-to-end because of its slightly higher cost."
        />
      </p>

      <h3><Bi zh="Table 3 — 綠洲 ROI（所有田 Lv 10）" en="Table 3 — Oasis ROI (all fields at Lv 10)" /></h3>
      <p style="font-size: var(--fs-sm); color: var(--text-2);">
        <Bi
          zh="格式：HMx → y 代表「英雄宅 Lv x、y 天回本」。括弧內是 Lumi 推薦「在田升到第幾 → 第幾級時捕綠洲最划算」（25/25 雙綠洲不含建議）。"
          en={`Format: "HMx → y" means "Hero's Mansion Lv x, y days to break even". Numbers in brackets = Lumi's recommended trigger point ("capture the oasis when your fields are at Lv X → Y"). 25/25 dual oases have no bracketed recommendation.`}
        />
      </p>
      <div class="table-wrap oasis-roi-wrap">
        <table class="oasis-roi">
          <thead>
            <tr>
              <th><span class="bi"><span data-lang="zh">首都配置</span><span data-lang="en">Crop layout</span></span></th>
              <th><span class="bi"><span data-lang="zh">50% 糧綠洲</span><span data-lang="en">50% crop oasis</span></span></th>
              <th><span class="bi"><span data-lang="zh">25% / 25% 雙綠洲</span><span data-lang="en">25% / 25% dual oasis</span></span></th>
              <th><span class="bi"><span data-lang="zh">25% 糧綠洲</span><span data-lang="en">25% crop oasis</span></span></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="layout">15c</td>
              <td><div class="hm">HM10 → 1.83 <span class="hint">(11→7)</span></div><div class="hm">HM15 → 6.08</div><div class="hm">HM20 → 25.32</div></td>
              <td><div class="hm">HM10 → 3.40</div><div class="hm">HM15 → 11.41</div><div class="hm">HM20 → 47.47</div></td>
              <td><div class="hm">HM10 → 3.63 <span class="hint">(8→9)</span></div><div class="hm">HM15 → 12.16</div><div class="hm">HM20 → 50.62</div></td>
            </tr>
            <tr>
              <td class="layout">9c</td>
              <td><div class="hm">HM10 → 3.01 <span class="hint">(all 8)</span></div><div class="hm">HM15 → 10.14</div><div class="hm">HM20 → 42.20</div></td>
              <td><div class="hm">HM10 → 4.53</div><div class="hm">HM15 → 15.21</div><div class="hm">HM20 → 63.30</div></td>
              <td><div class="hm">HM10 → 6.00 <span class="hint">(2→10)</span></div><div class="hm">HM15 → 20.27</div><div class="hm">HM20 → 84.34</div></td>
            </tr>
            <tr>
              <td class="layout">7c</td>
              <td><div class="hm">HM10 → 3.89 <span class="hint">(2→9)</span></div><div class="hm">HM15 → 13.04</div><div class="hm">HM20 → 54.25</div></td>
              <td><div class="hm">HM10 → 4.91</div><div class="hm">HM15 → 16.58</div><div class="hm">HM20 → 69.01</div></td>
              <td><div class="hm">HM10 → 7.77</div><div class="hm">HM15 → 26.05</div><div class="hm">HM20 → 108.42</div></td>
            </tr>
            <tr>
              <td class="layout">6c</td>
              <td><div class="hm">HM10 → 4.53 <span class="hint">(5→9)</span></div><div class="hm">HM15 → 15.21</div><div class="hm">HM20 → 63.30</div></td>
              <td><div class="hm">HM10 → 5.44</div><div class="hm">HM15 → 18.25</div><div class="hm">HM20 → 95.96</div></td>
              <td><div class="hm">HM10 → 9.01</div><div class="hm">HM15 → 30.42</div><div class="hm">HM20 → 126.59</div></td>
            </tr>
          </tbody>
        </table>
      </div>
      <Callout kind="tip" titleZh="怎麼讀 Table 3" titleEn="How to read Table 3">
        <p>
          <Bi
            zh="HM10 = Hero's Mansion Lv 10 只能佔 1 塊綠洲 —— 這格是你搶首塊綠洲時看的。15c + 50% 糧綠洲 + HM10 = 1.83 天回本（最香）。到了 HM20（可佔 3 塊），後兩塊邊際報酬遞減（+25% 加法疊加稀釋），所以 HM20 那一排的數字才會那麼大。"
            en="HM10 = Hero's Mansion Lv 10 can hold only 1 oasis — use this row when judging your first capture. A 15c + 50% crop oasis + HM10 = 1.83 days payback (the S-tier pick). By HM20 (3 slots), marginal returns shrink because +25% bonuses add linearly and dilute — that's why the HM20 row looks so big."
          />
        </p>
      </Callout>
      <Callout kind="warn" titleZh="觸發時機的判讀" titleEn="Reading the trigger hints">
        <p>
          <Bi
            zh={`括弧中的 "11→7" 等符號代表 Lumi 建議的捕綠洲時機：當你「第 11 塊田升到 Lv 7」時抓這塊綠洲最划算。"all 8" = 全部 8 塊都到指定等級，"2→10" = 第 2 塊到 Lv 10。所以 ROI 不只看表面天數，要搭配觸發時機才是 Lumi 的完整讀法。`}
            en={`Brackets like "11→7" are Lumi's capture timing: grab this oasis when "your 11th field hits Lv 7". "all 8" = all 8 fields at the stated level; "2→10" = second field up to Lv 10. ROI isn't just about days — match it with the trigger point for Lumi's complete reading.`}
          />
        </p>
      </Callout>
      <p style="font-size: var(--fs-sm); color: var(--text-2);">
        <Bi
          zh="來源：Lumi Travian Guide §5.3（PDF p. 11–12）。Lumi 原文：「ROI for Oasis - all fields at 10 | comment in bracket → recommendation when to get the oasis (25/25 not included)」。"
          en={`Source: Lumi Travian Guide §5.3 (PDF p. 11–12). Original caption: "ROI for Oasis - all fields at 10 | comment in bracket → recommendation when to get the oasis (25/25 not included)".`}
        />
      </p>
    </Section>

    <Section id="cp" titleZh="文化點與開村" titleEn="Culture points & expansion" eyebrow="Expansion">
      <h3><Bi zh="CP 計算公式" en="CP formula" /></h3>
      <pre>CP_at_level(L) = round(base × 1.2 ^ L)</pre>
      <p>
        <Bi
          zh="每棟建築有一個基礎 CP 值（村莊大樓 = 2，市場 = 3，大使 / 研究院 = 4，城鎮廳 / 皇宮 = 5，寶物庫 = 6，其他多為 1 或 2）。等級越高 CP 增速越快。"
          en="Each building has a base CP (Main Building = 2, Marketplace = 3, Embassy / Academy = 4, Town Hall / Palace = 5, Treasury = 6, most others 1 or 2). Higher levels give exponentially more CP."
        />
      </p>

      <h3><Bi zh="Lumi 建議：每村 CP 配方" en="Lumi baseline: CP per village" /></h3>
      <p>
        <Bi
          zh="村莊大樓 20 + 市場 20 + 大使 20 + 研究院 20 + 城鎮廳 10 = 529 CP/天。這是每個村的「最低被動 CP」基線。"
          en="Main Building 20 + Marketplace 20 + Embassy 20 + Academy 20 + Town Hall 10 = 529 CP/day. This is the minimum-passive-CP baseline every village should reach."
        />
      </p>

      <h3><Bi zh="開村所需 CP" en="CP required per village" /></h3>
      <DataTable
        headers={[
          { zh: '第幾村', en: 'Village #' },
          { zh: '單次需求', en: 'Delta CP' },
          { zh: '累積', en: 'Cumulative' },
        ]}
        rows={cpRows}
      />
      <p>
        <Bi
          zh="第 6 村起每村 +11,000 CP（與第 5 村相同增量）。"
          en="From village 6 onward each adds +11,000 CP (same delta as village 5)."
        />
      </p>

      <h3><Bi zh="慶典（Town Hall）" en="Celebrations (Town Hall)" /></h3>
      <ul>
        <li><Bi zh="小型慶典：TH Lv1+、24 小時、+500 CP、消耗約 19.5k 資源" en="Small celebration: TH Lv1+, 24 h, +500 CP, ~19.5k total cost" /></li>
        <li><Bi zh="大型慶典：TH Lv10+、60 小時、+2,000 CP，但成本是 5x" en="Great celebration: TH Lv10+, 60 h, +2,000 CP, but costs 5x" /></li>
      </ul>

      <h3><Bi zh="忠誠度與征服（Chiefing）" en="Loyalty & chiefing" /></h3>
      <p>
        <Bi
          zh="每個村莊有忠誠度（loyalty）值。預設 100，被攻擊 + 參議員/司令官/族長/州長/重步兵/Ephor/Jarl 同行時會降低。降至 0 = 易主。每場大型慶典把基線拉到 +25（共 125），這就是為什麼鐵砧主動辦慶典的原因。"
          en="Every village has a loyalty value, defaulting to 100. It drops when attacked by an army containing a chief unit (Senator/Chief/Chieftain/Nomarch/Logades/Ephor/Jarl). At 0 the village changes hands. A great celebration raises the baseline to 125 — that's why anvils proactively run them."
        />
      </p>
      <DataTable
        caption={{ zh: '單一 chief 攻擊降忠誠度範圍（依攻方士氣）', en: 'Loyalty drop per chief-led attack (varies by attacker morale)' }}
        headers={[
          { zh: '族別 / 單位', en: 'Tribe / unit' },
          { zh: '降幅範圍', en: 'Drop range' },
          { zh: '備註', en: 'Note' },
        ]}
        rows={[
          [{ zh: '參議員 (Senator, 羅馬人)', en: 'Senator (Roman)' }, '20–30%', { zh: '成本最高、平衡型', en: 'Most expensive, balanced' }],
          [{ zh: '族長 (Chieftain, 高盧人)', en: 'Chieftain (Gaul)' }, '20–25%', { zh: '稍便宜、稍弱', en: 'Slightly cheaper, slightly weaker' }],
          [{ zh: '司令官 (Chief, 日耳曼人)', en: 'Chief (Teuton)' }, '20–25%', { zh: '所有 chief 訓練最快（70,500s）', en: 'Trains fastest of all chiefs (70,500s)' }],
          [{ zh: '州長 (Nomarch, 埃及人)', en: 'Nomarch (Egyptian)' }, '20–25%', '—'],
          [{ zh: '重步兵 (Logades, 匈奴)', en: 'Logades (Hun)' }, '20–25%', '—'],
          [{ zh: 'Ephor (斯巴達人)', en: 'Ephor (Spartan)' }, '20–25%', { zh: '標準 chief 單位降忠誠度', en: 'Standard chief-unit loyalty reduction' }],
          [{ zh: 'Jarl (維京人)', en: 'Jarl (Viking)' }, '15–30%', { zh: '維京人英雄的 raid 忠誠傷害是獨立機制，不計入 Jarl 的擲骰', en: "Viking hero's raid loyalty damage is a separate mechanic, not part of Jarl's roll" }],
        ]}
      />
      <p>
        <Bi
          zh="實戰：拿一個 100 忠誠的村大概要 4–5 波 chief 攻擊。對方若維持 125（大慶典），則需 5–6 波。把 chief 集中在一個錘子（3-chief）= 一次出兵就完成征服 (solo chiefing)。"
          en="Practical: capturing a 100-loyalty village typically needs 4–5 chief-led waves. If the defender holds at 125 (great celeb running), 5–6 waves. Stacking 3 chiefs in one hammer = solo chiefing in a single send."
        />
      </p>
      <Callout kind="warn" titleZh="防守忠誠度的工具" titleEn="Defending loyalty">
        <p>
          <Bi
            zh="忠誠藥水（Tablet of Law，從冒險取得）：每用 1 個恢復 1% 忠誠。被精準連擊（.00 / .01 兩波）時，要在 .00 之前喝。可同時計時建造行宮/皇宮，等它們在 wave 中間完工 → 立刻把忠誠度回滿。"
            en="Loyalty Tablets (from adventures) restore 1% loyalty per use. Against tightly-timed waves (e.g., .00 + .01), drink BEFORE .00. You can also time a Residence/Palace upgrade to finish in the gap between waves — completion instantly restores loyalty."
          />
        </p>
      </Callout>
    </Section>

    <Section id="hero" titleZh="英雄系統" titleEn="Hero system" eyebrow="Hero">
      <h3><Bi zh="屬性點分配" en="Attribute points" /></h3>
      <ul>
        <li><strong><Bi zh="戰鬥力" en="Fighting strength" /></strong>: <Bi zh="羅馬人 +100/點；其他族 +80/點" en="Romans +100/pt, other tribes +80/pt" /></li>
        <li><strong><Bi zh="進攻加成" en="Off bonus" /></strong>: <Bi zh="+0.2% 同伍部隊攻擊/點，上限 +20%（100 點）" en="+0.2% attack per pt to the army this hero is in (max +20% at 100 pts)" /></li>
        <li><strong><Bi zh="防禦加成" en="Def bonus" /></strong>: <Bi zh="+0.2% 同伍部隊防禦/點，上限 +20%" en="+0.2% defense per pt, max +20%" /></li>
        <li><strong><Bi zh="資源採集" en="Resource production" /></strong>: <Bi zh="平均分四資源：+6/點/小時（每種 +1.5）；集中單一：+6/點/小時全入該資源" en="Split: +6/pt/hr (≈+1.5 each); focused on one resource: +6/pt/hr into that type" /></li>
      </ul>

      <Callout kind="warn" titleZh="保護期結束後" titleEn="After beginner protection">
        <p>
          <Bi
            zh="綠洲清理不再安全（被反爆就死）。把英雄轉成資源採集，穩定提供 4 種 / 小時的額外收入。Book of Wisdom 可重置屬性。"
            en="Oasis clears become risky (counter-attacks can kill the hero). Respec into resource production for a steady +hourly income. Book of Wisdom from adventures resets attribute points."
          />
        </p>
      </Callout>

      <h3><Bi zh="冒險系統 (Adventures)" en="Adventures" /></h3>
      <p>
        <Bi
          zh="英雄宅（Hero's Mansion）會在地圖上 spawn 冒險點：所有點都離 HM 最近的村莊不超過 30 格。每完成一次冒險可拿經驗值、銀幣或物品。"
          en="The Hero's Mansion spawns adventures on the map within 30 fields of the village holding it. Each completed adventure rewards XP, silver, or an item."
        />
      </p>
      <DataTable
        headers={[
          { zh: '難度', en: 'Difficulty' },
          { zh: 'HP 損失', en: 'HP loss' },
          { zh: '獎勵', en: 'Reward' },
        ]}
        rows={[
          [{ zh: '一般 (Normal)', en: 'Normal' }, '0–30%', { zh: '資源 / 銀幣 / 普通物品', en: 'Resources / silver / common item' }],
          [{ zh: '困難 (Difficult)', en: 'Difficult' }, '30–60%', { zh: '較好物品、較多銀幣', en: 'Better items, more silver' }],
          [{ zh: '極難 (Very difficult)', en: 'Very difficult' }, '60%+ (有死亡風險)', { zh: '頂級物品 + 籠子', en: 'Top-tier items + cages' }],
        ]}
      />
      <Callout kind="tip" titleZh="冒險前必模擬" titleEn="Always simulate before adventuring">
        <p>
          <Bi
            zh="點冒險按鈕後右鍵看戰鬥模擬。若 HP 損失預估 >30%，先補藥水（ointment / bandage）或讓英雄帶幾隻肉盾（埃及人奴隸民兵最便宜）。"
            en="Click the adventure → right-click to see the battle simulation. If predicted HP loss is >30%, use ointments / bandages first or bring cheap meat-shield troops (Egyptian Slave Militia is cheapest)."
          />
        </p>
      </Callout>

      <h3><Bi zh="英雄裝備 (Equipment)" en="Hero equipment" /></h3>
      <p>
        <Bi
          zh="英雄有 7 個裝備槽：頭盔、武器、左手、盔甲、靴子、馬匹、袋子。冒險獲得物品或拍賣場（Auctions）競標銀幣購買。"
          en="The hero has 7 equipment slots: helmet, weapon, left hand, armor, boots, horse, bag. Items come from adventures or via the silver auction house."
        />
      </p>
      <DataTable
        caption={{ zh: '常用物品類型（精選）', en: 'Common item types (selected)' }}
        headers={[
          { zh: '類型', en: 'Type' },
          { zh: '範例效果', en: 'Example effect' },
        ]}
        rows={[
          [{ zh: '頭盔 (Helmet)', en: 'Helmet' }, { zh: '+25% / +50% 兵種訓練速度 | +20% 經驗值', en: '+25% / +50% troop training speed | +20% XP' }],
          [{ zh: '武器 (Weapon, 各族不同)', en: 'Weapon (per tribe)' }, { zh: '對選定的 1 種兵 +50% 攻擊（斯巴達人：對該類別所有兵）', en: '+50% attack to 1 chosen unit (Spartans: all units of category)' }],
          [{ zh: '靴子 (Boots)', en: 'Boots' }, { zh: '+25% / +50% / +75% 英雄速度', en: '+25% / +50% / +75% hero speed' }],
          [{ zh: '盔甲 (Armor)', en: 'Armor' }, { zh: '+10% / +20% 英雄生命', en: '+10% / +20% hero HP' }],
          [{ zh: '坐騎 (Horse)', en: 'Horse' }, { zh: '騎乘時加速：T1 馬 +14 格/時、T2 馬（Pferd）+17、T3 馬（訓練馬 / 阿拉伯馬）+20', en: 'Riding speed bonus: T1 Horse +14 fields/hr, T2 Horse (Pferd) +17, T3 Horse (Training/Arabian) +20' }],
          [{ zh: '背袋 (Bag)', en: 'Bag' }, { zh: '+200/400/800 搬運容量', en: '+200/400/800 carrying capacity' }],
          [{ zh: '軟膏 (Ointment)', en: 'Ointment' }, { zh: '每次使用 +5 HP（消耗品）', en: '+5 HP per use (consumable)' }],
          [{ zh: '繃帶 (Bandage)', en: 'Bandage' }, { zh: '戰鬥後 +10–15 HP（消耗品）', en: '+10–15 HP after battle (consumable)' }],
          [{ zh: '水桶 (Bucket)', en: 'Bucket' }, { zh: '立即 +25 HP（稀有）', en: '+25 HP instantly (rare)' }],
          [{ zh: '籠子 (Cage)', en: 'Cage' }, { zh: '捕捉綠洲動物（不用戰鬥就清空綠洲）', en: 'Capture an oasis animal (use to clear oases without combat)' }],
          [{ zh: '智慧之書 (Book of Wisdom)', en: 'Book of Wisdom' }, { zh: '重置所有英雄技能點（消耗品）', en: 'Reset all hero skill points (consumable)' }],
          [{ zh: '法律石板 (Tablet of Law)', en: 'Tablet of Law' }, { zh: '每次使用恢復 1% 村莊忠誠度（防守用）', en: 'Restore village loyalty by 1% per use (defensive)' }],
        ]}
      />
      <p style="font-size: var(--fs-sm); color: var(--text-2);">
        <Bi
          zh="拍賣場（需村莊大樓 Lv 5）讓你用銀幣競標他人賣出的裝備。後期 +50% 訓練頭盔 / +50% 攻擊武器 / +75% 速度靴會競到 100k+ 銀幣。"
          en="Auctions (requires Main Building Lv 5) let you bid silver on items posted by other players. Late-game +50% training helmets / +50% attack weapons / +75% boots routinely sell for 100k+ silver."
        />
      </p>
    </Section>

    <Section id="cranny" titleZh="山洞 & 保護" titleEn="Cranny & protection" eyebrow="Defense">
      <h3><Bi zh="山洞容量" en="Cranny capacity" /></h3>
      <p>
        <Bi
          zh="Lv1 每種資源藏 200（四項共 800；高盧人 ×1.5 = 每種 300 / 共 1,200）；Lv10 最高每種 2,000（共 8,000）。高盧人享 ×1.5（Lv10 = 每種 3,000）。攻擊者先搶倉庫外資源，倉庫內的看不到。"
          en="Lv1 hides 200 per resource (800 total; Gauls ×1.5 = 300 per resource / 1,200 total). Lv10 (MAX) hides 2,000 per resource (8,000 total). Gauls get ×1.5 (Lv10 = 3,000 per resource). Raiders take resources above the cranny threshold first."
        />
      </p>

      <h3><Bi zh="商人" en="Merchants" /></h3>
      <DataTable
        headers={[
          { zh: '部族', en: 'Tribe' },
          { zh: '容量', en: 'Capacity' },
          { zh: '速度', en: 'Speed' },
        ]}
        rows={merchantRows}
      />
      <p>
        <Bi
          zh="商路辦公室（Trade Office）每級加成：羅馬人 +20%（Lv 20 = +400% / 5×）；其他族 +10%（Lv 20 = +200% / 3×）。羅馬人的容量基礎是 500 但 Lv20 變 2,500，超過所有其他族。"
          en="Trade Office bonus is tribe-dependent: Romans +20%/lv (Lv 20 = +400% / 5×); all other tribes +10%/lv (Lv 20 = +200% / 3×). Roman base capacity 500 grows to 2,500 at Lv 20 — surpassing every other tribe."
        />
      </p>
    </Section>

    <Section id="tournament-square" titleZh="競技場 (Tournament Square)" titleEn="Tournament Square" eyebrow="Long-distance speed">
      <p>
        <Bi
          zh="競技場是遠程攻擊加速建築。前 20 格速度不變；超過 20 格的部分，每升一級增加 10% 速度。Lv 20 最高 +200%（三倍速度）。"
          en="Tournament Square (TS) speeds up long-distance attacks. Trips ≤20 fields get no bonus; beyond 20 fields, each TS level adds +10% speed. Lv 20 maxes at +200% (3× speed)."
        />
      </p>

      <h3><Bi zh="計算公式" en="Formula" /></h3>
      <pre>effective_speed = base_speed × (1 + TS_level × 0.10)   for trips > 20 fields</pre>
      <p>
        <Bi
          zh="例：TT 基礎速度 19 格/小時。Lv 20 TS：前 20 格以 19 走，剩下距離以 19 × 3 = 57 格/小時走。"
          en="Example: Theutates Thunder at base speed 19. With TS Lv 20, first 20 fields at 19/hr, remainder at 19 × 3 = 57/hr."
        />
      </p>

      <Callout kind="tip" titleZh="誰值得升到 20？" titleEn="Who benefits most?">
        <p>
          <Bi
            zh="錘子必升 TS 20 — 跨象限打 op 時間差可以壓縮一半以上。Feeder/NPC 不用蓋。Anvil 建議 Lv 10+（可以趕 def call），不一定要 Lv 20。"
            en="Hammer villages MUST push TS to Lv 20 — halves cross-quadrant OP times. Feeders and NPC villages don't need it. Anvils: Lv 10+ suffices for def-call timing; Lv 20 optional."
          />
        </p>
      </Callout>

      <h3><Bi zh="上限：20 格內無效" en="Zero benefit under 20 fields" /></h3>
      <p>
        <Bi
          zh="TS 不加速近距離攻擊（20 格以內）。攻擊 10 格外目標 TS 幫不上忙，farming 用不到。"
          en="TS doesn't affect sub-20-field trips. Attacking neighbors 10 fields away gets no boost. Farming is unaffected."
        />
      </p>
    </Section>

    <Section id="alliance" titleZh="聯盟系統" titleEn="Alliance system" eyebrow="Multiplayer">
      <p>
        <Bi
          zh="加入聯盟需要 Embassy（大使館）。Embassy Lv 1 = 加入；Lv 3 = 創立。聯盟最多 60 名成員（大部分伺服器）。聯盟內可內部聊天、協同作戰、共享報告、設置聯盟寶物庫等。"
          en="Joining an alliance requires an Embassy. Embassy Lv 1 = join, Lv 3 = create. Most servers cap alliances at 60 members. Alliance grants internal chat, coordinated attack planning, shared reports, and alliance treasury slots."
        />
      </p>

      <h3><Bi zh="聯盟外交（Pacts）" en="Alliance diplomacy (pacts)" /></h3>
      <DataTable
        headers={[
          { zh: '關係', en: 'Relation' },
          { zh: '效果', en: 'Effect' },
        ]}
        rows={[
          [{ zh: '聯盟 / 互不侵犯 (Confederacy / NAP)', en: 'Confederacy / NAP' }, { zh: '不能互相攻擊；可派援軍', en: 'Cannot attack each other; reinforcements still allowed' }],
          [{ zh: 'WW 同盟 (Wonder of the World ally)', en: 'Wonder of the World ally' }, { zh: '可運送 Plans + 援軍駐守 WW', en: 'Can ship plans + reinforce WW' }],
          [{ zh: '宣戰 (War declaration)', en: 'War declaration' }, { zh: '官方標記為敵；某些伺服器給攻擊加成', en: 'Officially marked enemy; some servers grant attack bonuses' }],
          [{ zh: '友好（非正式）(Friendship)', en: 'Friendship (informal)' }, { zh: '基於信任、無遊戲內機制強制', en: 'Trust-based, no in-game enforcement' }],
        ]}
      />

      <Callout kind="tip" titleZh="新手選聯盟標準" titleEn="Picking an alliance as a beginner">
        <p>
          <Bi
            zh="挑活躍度高的聯盟最重要：日均線上人數越多 → 你的 def call 越快有人接。其次看領導層是否規劃 OP（Day 45 起）、是否分工（OFF / DEF / Feeder 各有對應人）。萬人聯盟若只是聊天群沒打仗，不如進 30 人但有計畫的小團。"
            en="Activity matters most: high concurrent online count = faster def-call response. Second priority: do leaders plan OPs (from Day 45)? Are roles split (OFF / DEF / Feeder)? A 30-person alliance with discipline beats a 100-person social-only group."
          />
        </p>
      </Callout>
    </Section>

    <Section id="plus-gold" titleZh="Plus 與金幣 (Gold)" titleEn="Plus & Gold" eyebrow="Premium">
      <p>
        <Bi
          zh="Travian 是免費遊戲但有付費功能（Gold）。買 Gold 不是必需的，但前期 +25% 產量幾乎是「主流玩家全買」的標準配置。"
          en="Travian is free-to-play with a premium currency (Gold). Buying gold isn't required, but the +25% production bonuses are standard among most competitive players in the early game."
        />
      </p>

      <h3><Bi zh="主要 Gold 功能" en="Main gold-purchased features" /></h3>
      <DataTable
        headers={[
          { zh: '功能', en: 'Feature' },
          { zh: '效果', en: 'Effect' },
          { zh: '估計成本', en: 'Cost (approx)' },
        ]}
        rows={[
          [{ zh: '+25% 木 / 土 / 鐵 / 糧 產量', en: '+25% Wood / Clay / Iron / Crop production' }, { zh: '啟用期間永久加成', en: 'Permanent boost while active' }, { zh: '每資源 5 金幣/天 或 全部 10/天', en: '5 gold/day per resource OR 10/day for all 4' }],
          [{ zh: '+25% 糧食產量（獨立購買）', en: '+25% Crop production (separately)' }, { zh: '獨立購買', en: 'Standalone purchase' }, '5 金幣/天'],
          [{ zh: '+25% 倉庫 / 穀倉容量', en: '+25% Warehouse / Granary capacity' }, { zh: '不用蓋建築就有更多儲存', en: 'More storage without building' }, '~3 金幣/天'],
          [{ zh: 'Plus 帳號', en: 'Plus Account' }, { zh: '更好的 UI、建築佇列加長、進階統計、列表檢視', en: 'Better UI, build-queue extender, advanced stats, list views' }, { zh: '10 金幣 / 7 天（1x 伺服器）', en: '10 gold / 7 days (1x server)' }],
          [{ zh: 'NPC 商人', en: 'NPC Trader' }, { zh: '在市場以 1:1 比例交換資源', en: 'Swap resources at marketplace at 1:1 ratio' }, '每次 3 金幣'],
          [{ zh: '拍賣場（用銀幣競標）', en: 'Auctions (silver bidding)' }, { zh: '從冒險取得銀幣，不需金幣', en: 'Earned via adventures, no gold needed' }, '—'],
