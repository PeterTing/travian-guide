        rows={[
          ['4P Sim',     '1,867', '890', '+977',  { zh: '需外部資源（冒險/任務/綠洲）', en: 'Needs external (adventures/tasks/oasis)' }],
          ['4P Farming', '1,602', '890', '+712',  { zh: '需 farming ~700/hr', en: 'Needs farming ~700/hr' }],
