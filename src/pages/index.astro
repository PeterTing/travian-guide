---
import BaseLayout from '../layouts/BaseLayout.astro';
import Bi from '../components/shared/Bi.astro';
---
<BaseLayout>
  <section style="padding: var(--space-9) var(--space-5); max-width: var(--container); margin: 0 auto; text-align: center;">
    <h1 style="font-size: var(--fs-5xl); margin-bottom: var(--space-4);">
      <Bi zh="Travian Legends 攻略" en="Travian Legends Guide" />
    </h1>
    <p style="color: var(--text-1); font-size: var(--fs-lg); max-width: 640px; margin: 0 auto;">
      <Bi
        zh="T4.6 x1 速度 — 以 Lumi / Eggstra / Dave 進階指南為基礎。完整頁面正在建置中。"
        en="T4.6 1x speed — based on the Lumi / Eggstra / Dave advanced guide. Full pages landing soon."
      />
    </p>
  </section>
</BaseLayout>
