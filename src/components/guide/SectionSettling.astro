---
import Bi from '../shared/Bi.astro';
import Callout from '../shared/Callout.astro';
import Section from '../mechanics/Section.astro';
import { SETTLEMENT_LIST } from '../../data/settlement/index';
import { TRIBES } from '../../data/tribes/index';
---
<Section
  id="settling"
  titleZh="選一個族"
  titleEn="Pick your tribe"
  eyebrow="Step 1 · before strategy selector"
>
  <p>
    <Bi
      zh="開局建築順序對 7 個族幾乎一樣（xlsx 的 40 步共通前綴，之後依「風格」而非「族」分支）。族別只影響最後訓練 3 個 settler 的成本、獨特單位、和族特色（羅馬雙隊列 / 高盧陷阱 / 條頓早期掠奪）。下面是每族的開局性格。"
      en="The opening build order is nearly identical across all 7 tribes (xlsx's 40-step common prefix, then branches by strategy, not tribe). Tribe choice affects only the final 3-settler cost, the tribe's unique unit, and qualitative early-game flavor (Roman dual queue / Gaul Trapper / Teuton early raiding). Each tribe's opening character below."
    />
  </p>

  <Callout kind="tip" titleZh="下一步" titleEn="Next step">
    <p>
      <Bi
        zh="選好族之後，捲到下面「先選一個開局風格」（#style-selector）決定 Sim / Farming / Lazy 路線，再看「建築順序」（#build-order）。"
        en="After picking a tribe, scroll to the Style Selector (#style-selector) to choose Sim / Farming / Lazy, then see the actual build order (#build-order)."
      />
    </p>
  </Callout>

  <div class="tribe-grid">
    {SETTLEMENT_LIST.map(s => {
      const tribe = TRIBES[s.tribe];
      return (
        <article class="tribe-card" style={`--tribe-accent: ${tribe.color}`}>
          <h3 class="tribe-head">
            <span class="tribe-icon" aria-hidden="true">{tribe.icon}</span>
            <span class="tribe-name">
              <Bi zh={tribe.name.zh} en={tribe.name.en} />
            </span>
          </h3>
          <p class="tribe-approach">
            <Bi zh={s.approach.zh} en={s.approach.en} />
          </p>
          <h4 class="tips-head">
            <Bi zh="關鍵要點" en="Key tips" />
          </h4>
          <ul class="tips">
            {s.keyTips.map(tip => (
              <li><Bi zh={tip.zh} en={tip.en} /></li>
            ))}
          </ul>
        </article>
      );
    })}
  </div>

  <Callout kind="info" titleZh="想深入族別？" titleEn="Want more on tribes?">
    <p>
      <Bi
        zh="每族的兵種、建築、英雄獨特性見"
        en="Per-tribe units, buildings, hero specifics: "
      />
      <a href="/tribes">
        <Bi zh="族別頁面" en="/tribes" />
      </a>
      <Bi zh="。族別 settler 成本詳細對照表見" en=". Settler cost comparison at " />
      <a href="#build-order">
        <Bi zh="建築順序區" en="#build-order" />
      </a>
      .
    </p>
  </Callout>
</Section>

<style>
  .tribe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin: 24px 0;
  }
  .tribe-card {
    border: 1px solid var(--border-0);
    border-left: 3px solid var(--tribe-accent, var(--accent));
    border-radius: 8px;
    background: var(--bg-1);
    padding: 16px 18px;
  }
  .tribe-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 10px;
    font-size: 18px;
    color: var(--text-0);
  }
  .tribe-icon {
    font-size: 22px;
  }
  .tribe-name {
    font-weight: 600;
  }
  .tribe-approach {
    margin: 0 0 14px;
    color: var(--text-1);
    font-size: 14px;
    line-height: 1.65;
  }
  .tips-head {
    margin: 14px 0 8px;
    font-size: 13px;
    color: var(--text-2);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .tips {
    margin: 0;
    padding-left: 20px;
    color: var(--text-1);
    font-size: 13px;
    line-height: 1.6;
  }
  .tips li {
    margin-bottom: 6px;
  }
  .tips li:last-child {
    margin-bottom: 0;
  }
</style>
