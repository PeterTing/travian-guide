---
import Bi from '../shared/Bi.astro';
import Callout from '../shared/Callout.astro';
import Section from '../mechanics/Section.astro';
import { LangProvider } from '../../i18n/LangContext.tsx';
import StrategyTabs from './StrategyTabs.tsx';
import TribeCostTable from './TribeCostTable.astro';
---
<Section
  id="build-order"
  titleZh="開局建築順序（按策略風格）"
  titleEn="Opening build order (by strategy)"
  eyebrow="Step by step"
>
  <p>
    <Bi
      zh="下面 5 種風格對應 xlsx 的 5 個 sheet，都假設 1x 伺服器速度 + Plus 金幣 +25% 產量。前 40 步所有風格共通，Day 2 後分支。建議先用上方「風格選擇器」選出你的風格，再按步驟走。"
      en="Five strategy branches mapped from the xlsx (Carpis guide). All assume 1x speed + Plus gold +25% production. The first 40 steps are shared across all 5 strategies; branches diverge from Day 2. Use the style selector above to pick yours first."
    />
  </p>

  <Callout kind="tip" titleZh="共通原則" titleEn="Universal principles">
    <ul>
      <li>
        <Bi
          zh="Hour 0 立刻加入聯盟（不然新手加成會跑掉）"
          en="Join an alliance at Hour 0 (before newbie bonus expires)"
        />
      </li>
      <li>
        <Bi
          zh="英雄前 3 天全點戰鬥力（打綠洲），Day 3 後用智慧之書重置成資源採集"
          en="Hero → Fighting Strength for Days 1–3 (clear oases), respec to Resources with Book of Wisdom after Day 3"
        />
      </li>
      <li>
        <Bi
          zh="Residence Lv 10 是解鎖 Settler 的門檻（xlsx 所有風格都在 Residence 10 之後才訓 settler）"
          en="Residence Lv 10 unlocks Settlers (all 5 xlsx strategies train settlers only after Residence reaches Lv 10)"
        />
      </li>
      <li>
        <Bi
          zh="保護期結束前秘密倉庫拉到 Lv 10（高盧 Lv 7 即可，因為 ×1.5）"
          en="Cranny Lv 10 before protection ends (Gauls can stop at Lv 7 thanks to ×1.5 bonus)"
        />
      </li>
    </ul>
  </Callout>

  <LangProvider client:load>
    <StrategyTabs client:load />
  </LangProvider>

  <Callout kind="info" titleZh="族別 settler 成本（影響最後訓練 3 個 settler）" titleEn="Settler cost by tribe (affects only the final 3-settler training)">
    <p>
      <Bi
        zh="開局 build order 本身不因族而異（前 78-102 步都一樣）。差別只在最後訓練 3 個 settler 的成本。詳細對照表由下方 TribeCostTable 元件提供。"
        en="The opening build order itself is tribe-agnostic (first 78-102 steps are identical). Only the final 3-settler training cost differs by tribe. See the TribeCostTable below for details."
      />
    </p>
    <TribeCostTable />
  </Callout>
</Section>
