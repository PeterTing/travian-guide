---
import Bi from '../shared/Bi.astro';
import Callout from '../shared/Callout.astro';
import Section from '../mechanics/Section.astro';
import { LangProvider } from '../../i18n/LangContext.tsx';
import BuildOrderTabs from './BuildOrderTabs.tsx';
---
<Section id="build-order" titleZh="最快開二村建築順序" titleEn="Fastest 2nd-village build order" eyebrow="Hour by hour">
  <p>
    <Bi
      zh="下面是各族「Day 0 → Day 5–8 定居」的時程表。所有時間假設 1x 伺服器速度 + Plus 金幣 +25% 產量加成。如果你玩的是 x3 伺服器，把小時 / 天數除以 3 即可。"
      en="Per-tribe Day 0 → Day 5–8 settlement timelines. All hours assume 1x speed + Plus gold +25% production. For x3 servers, divide times by 3."
    />
  </p>

  <Callout kind="tip" titleZh="共通原則" titleEn="Universal principles">
    <ul>
      <li><Bi zh="Hour 0 立刻加入聯盟（不然新手加成會跑掉）" en="Join an alliance at Hour 0 (before newbie bonus expires)" /></li>
      <li><Bi zh="英雄前 3 天全點戰鬥力（打綠洲），Day 3 後用智慧之書重置成資源採集" en="Hero → Fighting Strength for Days 1–3 (clear oases), respec to Resources with Book of Wisdom after Day 3" /></li>
      <li><Bi zh="Residence Lv 10 是關鍵門檻（可以訓練開拓者），所有族最晚 Day 4 要到" en="Residence Lv 10 is the gating threshold (enables Settler training). All tribes should reach it by Day 4 at latest" /></li>
      <li><Bi zh="保護期結束前秘密倉庫拉到 Lv 10（高盧 Lv 7 即可，因為 ×1.5）" en="Cranny Lv 10 before protection ends (Gauls can stop at Lv 7 thanks to ×1.5 bonus)" /></li>
    </ul>
  </Callout>

  <LangProvider client:load>
    <BuildOrderTabs client:load />
  </LangProvider>

  <Callout kind="info" titleZh="資源預估" titleEn="Resource estimate">
    <p>
      <Bi
        zh="3 個開拓者成本：高盧最便宜（54,300 總資源）、羅馬 57,000、條頓 60,000、其他 4 族約 60,000–75,000。如果你 Day 4 結束時還沒這麼多資源，延到 Day 6 或 Day 7 再開二村比硬擠好（硬擠會讓首都發展停頓）。"
        en="3 Settlers cost: Gauls cheapest (54,300 total), Romans ~57,000, Teutons ~60,000, others ~60,000–75,000. If Day 4 ends without sufficient resources, delay settling to Day 6–7 rather than crash the capital economy."
      />
    </p>
  </Callout>
</Section>
