---
import Bi from './Bi.astro';
import styles from './Footer.module.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---
<footer class={styles.footer}>
  <div class={styles.inner}>
    <div class={styles.col}>
      <h4 class={styles.heading}><Bi zh="е…§е®№" en="Content" /></h4>
      <ul class={styles.list}>
        <li><a href={`${base}/guide`}><Bi zh="ж–°жүӢж”»з•Ҙ" en="Beginner Guide" /></a></li>
        <li><a href={`${base}/mechanics`}><Bi zh="йҒҠжҲІж©ҹеҲ¶" en="Game Mechanics" /></a></li>
        <li><a href={`${base}/strategy`}><Bi zh="йҖІйҡҺзӯ–з•Ҙ" en="Advanced Strategy" /></a></li>
      </ul>
    </div>

    <div class={styles.col}>
      <h4 class={styles.heading}><Bi zh="е·Ҙе…·" en="Tools" /></h4>
      <ul class={styles.list}>
        <li><a href={`${base}/tools#field-roi`}><Bi zh="иіҮжәҗз”° ROI" en="Field ROI" /></a></li>
        <li><a href={`${base}/tools#oasis-roi`}><Bi zh="з¶ жҙІ ROI" en="Oasis ROI" /></a></li>
        <li><a href={`${base}/tools#cp`}><Bi zh="ж–ҮеҢ–й»һиЁҲз®—" en="Culture Points" /></a></li>
        <li><a href={`${base}/tools#traderoute`}><Bi zh="е•Ҷи·ҜиҰҸеҠғ" en="Trade Routes" /></a></li>
      </ul>
    </div>

    <div class={styles.col}>
      <h4 class={styles.heading}><Bi zh="йғЁж—Ҹ" en="Tribes" /></h4>
      <ul class={styles.list}>
        <li><a href={`${base}/tribes/romans`}>Romans</a></li>
        <li><a href={`${base}/tribes/gauls`}>Gauls</a></li>
        <li><a href={`${base}/tribes/teutons`}>Teutons</a></li>
        <li><a href={`${base}/tribes/egyptians`}>Egyptians</a></li>
        <li><a href={`${base}/tribes/huns`}>Huns</a></li>
        <li><a href={`${base}/tribes/vikings`}>Vikings</a></li>
        <li><a href={`${base}/tribes/spartans`}>Spartans</a></li>
      </ul>
    </div>

    <div class={styles.col}>
      <h4 class={styles.heading}><Bi zh="й—ңж–ј" en="About" /></h4>
      <p class={styles.about}>
        <Bi
          zh="еҹәж–ј Lumi / Eggstra / Dave йҖІйҡҺжҢҮеҚ—пјӣиіҮж–ҷжәҗиҮӘ kirilloid/travianгҖӮжң¬з«ҷйқһе®ҳж–№пјҢиҲҮ Travian Games з„Ўй—ңгҖӮ"
          en="Based on the Lumi / Eggstra / Dave advanced guide; data sourced from kirilloid/travian. Unofficial, not affiliated with Travian Games."
        />
      </p>
    </div>
  </div>

  <div class={styles.bottom}>
    <span>В© {year} Travian Guide</span>
    <span class={styles.dot}>В·</span>
    <Bi zh="Travian зӮә Travian Games GmbH е•ҶжЁҷ" en="Travian is a trademark of Travian Games GmbH" />
  </div>
</footer>
