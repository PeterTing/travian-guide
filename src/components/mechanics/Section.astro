---
interface Props {
  id?: string;
  titleZh: string;
  titleEn: string;
  eyebrow?: string;
}
const { id, titleZh, titleEn, eyebrow } = Astro.props;
---
<section id={id} class="mechanics-section">
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2>
    <span class="bi"><span data-lang="zh">{titleZh}</span><span data-lang="en">{titleEn}</span></span>
  </h2>
  <div class="section-body">
    <slot />
  </div>
</section>

<style>
  .mechanics-section {
    padding: 48px 0;
    border-top: 1px solid var(--border-0);
    scroll-margin-top: 80px;
  }
  .mechanics-section:first-of-type { border-top: 0; padding-top: 0; }
  .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 10px;
    font-weight: 500;
  }
  h2 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
  }
  .section-body :global(h3) {
    font-size: 18px;
    margin: 28px 0 12px;
    color: var(--text-0);
  }
  .section-body :global(p) {
    color: var(--text-1);
    line-height: 1.7;
    margin: 0 0 12px;
  }
  .section-body :global(ul), .section-body :global(ol) {
    padding-left: 20px;
    color: var(--text-1);
  }
  .section-body :global(li) { margin-bottom: 6px; line-height: 1.6; }
</style>
